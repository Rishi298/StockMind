# StockMind Terminal — Environment Variables
# No API keys required for MVP (uses yahoo-finance2 which is free)

# Optional: Upgrade data sources
# ALPHA_VANTAGE_API_KEY=your_key_here       # alphavantage.co — free tier 25 req/day
# FINNHUB_API_KEY=your_key_here             # finnhub.io — free tier 60 req/min
# POLYGON_API_KEY=your_key_here             # polygon.io — paid, institutional grade

# Optional: Cache configuration
# CACHE_TTL_SECONDS=60                      # Default: 60s in-memory cache

# Optional: Rate limiting (Vercel KV or Upstash)
# KV_REST_API_URL=your_url_here
# KV_REST_API_TOKEN=your_token_here

# ─── Portfolio Manager (new features) ───────────────────────────────────────

# Email notifications (Gmail SMTP)
# 1. Enable 2FA on your Google account
# 2. Generate an App Password at: https://myaccount.google.com/apppasswords
EMAIL_FROM=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password_here

# Zerodha Kite Connect (optional — CSV import always works without this)
# 1. Apply for Kite Connect API at: https://developers.kite.trade/
# 2. Create an app and get your API key & secret
ZERODHA_API_KEY=your_kite_api_key_here
ZERODHA_API_SECRET=your_kite_api_secret_here

# Redirect URI to configure in your Zerodha Kite app:
# http://localhost:3000/api/zerodha/auth (dev)
# https://yourdomain.com/api/zerodha/auth (prod)
